// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  userId      String   @id @map("user_id") @db.Uuid
  username    String?  @unique
  fullName    String?  @map("full_name")
  avatarUrl   String?  @map("avatar_url")
  avatarColor String?  @map("avatar_color")
  location    String?
  notificationSettings Json?   @map("notification_settings")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  interests     ProfileInterest[]
  events        Event[]              @relation("events_created_by")
  attendees     EventAttendee[]
  tickets       Ticket[]
  conversations ConversationMember[]
  sentMessages  Message[]
  notifications Notification[]
  paymentOrders PaymentOrder[]

  @@map("profiles")
}

model Interest {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  profiles ProfileInterest[]
  events   EventInterest[]

  @@map("interests")
}

model ProfileInterest {
  userId     String   @map("user_id") @db.Uuid
  interestId String   @map("interest_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  profile  Profile  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  interest Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@id([userId, interestId])
  @@map("profile_interests")
}

model Provider {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  handle      String?  @unique
  description String?
  websiteUrl  String?  @map("website_url")
  logoUrl     String?  @map("logo_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  events   Event[]
  reviews  ProviderReview[]

  @@map("providers")
}

model Event {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId       String?   @map("provider_id") @db.Uuid
  title            String
  description      String?
  startsAt         DateTime? @map("starts_at") @db.Timestamptz(6)
  endsAt           DateTime? @map("ends_at") @db.Timestamptz(6)
  city             String?
  venue            String?
  address          String?
  latitude         Float?   @map("latitude") @db.DoublePrecision
  longitude        Float?   @map("longitude") @db.DoublePrecision
  coverImageUrl    String?   @map("cover_image_url")
  themeColor       String?   @map("theme_color")
  smokingAllowed   Boolean   @default(false) @map("smoking_allowed")
  petFriendly      Boolean   @default(false) @map("pet_friendly")
  parkingAvailable Boolean   @default(false) @map("parking_available")
  minAge           Int?      @map("min_age")
  eventType        String    @default("single") @map("event_type")
  recurrence       String?
  recurrenceCustom Json?     @map("recurrence_custom")
  ticketMode       String    @default("paid") @map("ticket_mode")
  capacity         Int       @default(0)
  status           String    @default("draft")
  createdBy        String?   @map("created_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  provider      Provider?       @relation(fields: [providerId], references: [id], onDelete: SetNull)
  creator       Profile?        @relation("events_created_by", fields: [createdBy], references: [userId], onDelete: SetNull)
  attendees     EventAttendee[]
  interests     EventInterest[]
  media         EventMedia[]
  tickets       Ticket[]
  paymentOrders PaymentOrder[]

  @@index([startsAt])
  @@index([providerId])
  @@map("events")
}

model EventMedia {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, sortOrder, createdAt])
  @@map("event_media")
}

model ProviderReview {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId String   @map("provider_id") @db.Uuid
  authorName String   @map("author_name")
  body       String
  rating     Int?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, createdAt(sort: Desc)])
  @@map("provider_reviews")
}

model EventInterest {
  eventId    String   @map("event_id") @db.Uuid
  interestId String   @map("interest_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  interest Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@id([eventId, interestId])
  @@map("event_interests")
}

model EventAttendee {
  eventId   String   @map("event_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  status    String   @default("going")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([eventId, userId])
  @@map("event_attendees")
}

enum TicketTab {
  eventos
  clases
}

model Ticket {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId        String    @map("owner_id") @db.Uuid
  eventId        String?   @map("event_id") @db.Uuid
  paymentOrderId String?   @map("payment_order_id") @db.Uuid
  title          String
  tab            TicketTab @default(eventos)
  themeColor     String?   @map("theme_color")
  attendeeCount  Int       @default(0) @map("attendee_count")
  cancelledAt    DateTime? @map("cancelled_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  owner        Profile       @relation(fields: [ownerId], references: [userId], onDelete: Cascade)
  event        Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  paymentOrder PaymentOrder? @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)
  refunds      Refund[]

  @@index([ownerId])
  @@index([eventId])
  @@index([paymentOrderId])
  @@map("tickets")
}

model Conversation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  members  ConversationMember[]
  messages Message[]

  @@map("conversations")
}

model ConversationMember {
  conversationId String   @map("conversation_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  profile      Profile      @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  body           String
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Profile      @relation(fields: [senderId], references: [userId], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

enum NotificationTab {
  amigos
  eventos
  menciones
}

model Notification {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String            @map("user_id") @db.Uuid
  dedupeKey     String?           @map("dedupe_key")
  categoryLabel String?           @map("category_label")
  title         String
  description   String?
  relevantTabs  NotificationTab[] @map("relevant_tabs")
  readAt        DateTime?         @map("read_at") @db.Timestamptz(6)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  profile Profile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

enum PaymentOrderStatus {
  pending_payment
  paid
  failed
  cancelled
  refunded

  @@map("payment_order_status")
}

model PaymentOrder {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String             @map("user_id") @db.Uuid
  eventId           String             @map("event_id") @db.Uuid
  entryTypeId       String?            @map("entry_type_id") @db.Uuid
  quantity          Int                @default(1)
  amountCents       Int                @map("amount_cents")
  currency          String             @default("HNL") @db.VarChar(3)
  status            PaymentOrderStatus @default(pending_payment)
  paygateLinkId     String?            @unique @map("paygate_link_id")
  paygatePaymentId  String?            @unique @map("paygate_payment_id")
  paygateRawWebhook Json?              @map("paygate_raw_webhook")
  resolutionSource  String?            @map("resolution_source")
  expiresAt         DateTime?          @map("expires_at") @db.Timestamptz(6)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)

  user    Profile  @relation(fields: [userId], references: [userId], onDelete: Restrict)
  event   Event    @relation(fields: [eventId], references: [id], onDelete: Restrict)
  tickets Ticket[]
  refunds Refund[]

  @@index([userId])
  @@index([eventId])
  @@index([status])
  @@map("payment_orders")
}

/// Paygate orders for provider annual subscription purchases. Kept separate
/// from `payment_orders` (ticket purchases) so the live ticket flow stays
/// untouched. Fulfillment activates the plan in the owner's user_metadata.
model ProviderSubscriptionOrder {
  id                String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId        String             @map("provider_id") @db.Uuid
  userId            String             @map("user_id") @db.Uuid
  planId            String             @map("plan_id")
  amountCents       Int                @map("amount_cents")
  currency          String             @default("HNL") @db.VarChar(3)
  status            PaymentOrderStatus @default(pending_payment)
  paygateLinkId     String?            @unique @map("paygate_link_id")
  paygatePaymentId  String?            @unique @map("paygate_payment_id")
  paygateRawWebhook Json?              @map("paygate_raw_webhook")
  /// Set for prorated upgrades — activation keeps this exact term end instead
  /// of extending a year. Null for full new-term purchases/renewals.
  periodEnd         DateTime?          @map("period_end") @db.Timestamptz(6)
  expiresAt         DateTime?          @map("expires_at") @db.Timestamptz(6)
  createdAt         DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([providerId])
  @@index([userId])
  @@index([status])
  @@map("provider_subscription_orders")
}

model Refund {
  id                            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  paymentOrderId                String       @map("payment_order_id") @db.Uuid
  ticketId                      String?      @map("ticket_id") @db.Uuid
  userId                        String       @map("user_id") @db.Uuid
  amountCents                   Int          @map("amount_cents")
  currency                      String       @default("HNL")
  reason                        String
  status                        String
  policyEligibleAtRequest       Boolean      @map("policy_eligible_at_request")
  policyDeadlineHoursAtRequest  Int?         @map("policy_deadline_hours_at_request")
  paygatePaymentId              String?      @map("paygate_payment_id")
  paygateRefundResponse         Json?        @map("paygate_refund_response")
  notes                         String?
  requestedAt                   DateTime     @default(now()) @map("requested_at") @db.Timestamptz(6)
  resolvedAt                    DateTime?    @map("resolved_at") @db.Timestamptz(6)
  updatedAt                     DateTime     @default(now()) @map("updated_at") @db.Timestamptz(6)

  paymentOrder PaymentOrder @relation(fields: [paymentOrderId], references: [id], onDelete: Restrict)
  ticket       Ticket?      @relation(fields: [ticketId], references: [id], onDelete: SetNull)

  @@index([paymentOrderId])
  @@index([status, requestedAt(sort: Desc)])
  @@index([userId, requestedAt(sort: Desc)])
  @@map("refunds")
}

/// Registro append-only para acciones del panel **allons-admin**
/// (suspend/ban usuarios, estados proveedor, eventos, waitlist QR).
/// Solo insertar desde servidor con medio de confianza tras gate root — ver trigger en migración.
model AdminAuditLog {
  id String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  occurredAt DateTime @default(now()) @map("occurred_at") @db.Timestamptz(6)

  actorUserId String? @map("actor_user_id") @db.Uuid
  actorEmail  String? @map("actor_email")

  source String /// server_action \| route_handler
  action String

  resourceType String @map("resource_type")
  resourceId   String @map("resource_id")

  /// success \| failure — validación adicional CHECK en Postgres (migración)
  outcome String

  httpMethod String? @map("http_method")
  httpPath   String? @map("http_path")

  ipAddress  String? @map("ip_address")
  userAgent  String? @map("user_agent")

  correlationId   String? @map("correlation_id") @db.Uuid
  clientRequestId String? @map("client_request_id")

  errorCode    String? @map("error_code")
  errorMessage String? @map("error_message")

  stateBefore Json @default("{}") @map("state_before") @db.JsonB
  stateAfter  Json @default("{}") @map("state_after") @db.JsonB

  @@index([occurredAt(sort: Desc)])
  @@index([resourceType, resourceId])
  @@index([actorUserId])
  @@index([action])
  @@map("admin_audit_logs")
}
