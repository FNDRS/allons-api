// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Profile {
  userId      String   @id @map("user_id") @db.Uuid
  username    String?  @unique
  fullName    String?  @map("full_name")
  avatarUrl   String?  @map("avatar_url")
  avatarColor String?  @map("avatar_color")
  location    String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  interests     ProfileInterest[]
  events        Event[]              @relation("events_created_by")
  attendees     EventAttendee[]
  tickets       Ticket[]
  conversations ConversationMember[]
  sentMessages  Message[]
  notifications Notification[]

  @@map("profiles")
}

model Interest {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  profiles ProfileInterest[]
  events   EventInterest[]

  @@map("interests")
}

model ProfileInterest {
  userId     String   @map("user_id") @db.Uuid
  interestId String   @map("interest_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  profile  Profile  @relation(fields: [userId], references: [userId], onDelete: Cascade)
  interest Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@id([userId, interestId])
  @@map("profile_interests")
}

model Provider {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  handle      String?  @unique
  description String?
  websiteUrl  String?  @map("website_url")
  logoUrl     String?  @map("logo_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  events   Event[]
  reviews  ProviderReview[]

  @@map("providers")
}

model Event {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId       String?   @map("provider_id") @db.Uuid
  title            String
  description      String?
  startsAt         DateTime? @map("starts_at") @db.Timestamptz(6)
  endsAt           DateTime? @map("ends_at") @db.Timestamptz(6)
  city             String?
  venue            String?
  address          String?
  coverImageUrl    String?   @map("cover_image_url")
  themeColor       String?   @map("theme_color")
  smokingAllowed   Boolean   @default(false) @map("smoking_allowed")
  petFriendly      Boolean   @default(false) @map("pet_friendly")
  parkingAvailable Boolean   @default(false) @map("parking_available")
  minAge           Int?      @map("min_age")
  createdBy        String?   @map("created_by") @db.Uuid
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)

  provider  Provider?       @relation(fields: [providerId], references: [id], onDelete: SetNull)
  creator   Profile?        @relation("events_created_by", fields: [createdBy], references: [userId], onDelete: SetNull)
  attendees EventAttendee[]
  interests EventInterest[]
  media     EventMedia[]
  tickets   Ticket[]

  @@index([startsAt])
  @@index([providerId])
  @@map("events")
}

model EventMedia {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId   String   @map("event_id") @db.Uuid
  url       String
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@index([eventId, sortOrder, createdAt])
  @@map("event_media")
}

model ProviderReview {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  providerId String   @map("provider_id") @db.Uuid
  authorName String   @map("author_name")
  body       String
  rating     Int?
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  provider   Provider @relation(fields: [providerId], references: [id], onDelete: Cascade)

  @@index([providerId, createdAt(sort: Desc)])
  @@map("provider_reviews")
}

model EventInterest {
  eventId    String   @map("event_id") @db.Uuid
  interestId String   @map("interest_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  event    Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  interest Interest @relation(fields: [interestId], references: [id], onDelete: Cascade)

  @@id([eventId, interestId])
  @@map("event_interests")
}

model EventAttendee {
  eventId   String   @map("event_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  status    String   @default("going")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([eventId, userId])
  @@map("event_attendees")
}

enum TicketTab {
  eventos
  clases
}

model Ticket {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  ownerId       String    @map("owner_id") @db.Uuid
  eventId       String?   @map("event_id") @db.Uuid
  title         String
  tab           TicketTab @default(eventos)
  themeColor    String?   @map("theme_color")
  attendeeCount Int       @default(0) @map("attendee_count")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  owner Profile @relation(fields: [ownerId], references: [userId], onDelete: Cascade)
  event Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([eventId])
  @@map("tickets")
}

model Conversation {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  members  ConversationMember[]
  messages Message[]

  @@map("conversations")
}

model ConversationMember {
  conversationId String   @map("conversation_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  profile      Profile      @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@id([conversationId, userId])
  @@map("conversation_members")
}

model Message {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String   @map("conversation_id") @db.Uuid
  senderId       String   @map("sender_id") @db.Uuid
  body           String
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Profile      @relation(fields: [senderId], references: [userId], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

enum NotificationTab {
  amigos
  eventos
  menciones
}

model Notification {
  id            String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String            @map("user_id") @db.Uuid
  categoryLabel String?           @map("category_label")
  title         String
  description   String?
  relevantTabs  NotificationTab[] @map("relevant_tabs")
  readAt        DateTime?         @map("read_at") @db.Timestamptz(6)
  createdAt     DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)

  profile Profile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}
