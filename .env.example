PORT=3000

# Connect to Supabase via connection pooling (recommended for runtime)
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require

# Direct connection to the database. Used for migrations (may not work on all networks)
DIRECT_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?sslmode=require

# Optional: Supabase Admin (server-side) access for auth/user-linked mutations
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Opcional: `pnpm db:seed` — UUID en Supabase Auth del organizador dueño del proveedor del panel.
# SEED_PANEL_PROVIDER_USER_ID=
# (obsoleto, aún aceptado: SEED_DEMO_PROVIDER_USER_ID)

# Destructive dev seed — wipes app data + deletes ALL Supabase Auth users except what the seed recreates.
# Does NOT truncate waitlist, waitlist_qr_sources (or views).
#
# ALLOW_DEV_DATABASE_RESET=yes
# DEV_SEED_PASSWORD=choose-a-strong-temp-password
# Opcional: prefijo del correo local ({prefijo}+cliente|comercio|staff@allonsapp.com). Por defecto: dev
# DEV_SEED_EMAIL_PREFIX=dev

# Las cuentas que crea dev-reset usan DEV_SEED_EMAIL_PREFIX (por defecto dev); ver prisma/scripts/dev-reset-seed.ts.

# --- Paygate (Clinpays) — integración de pagos ---
# Sandbox:    https://stage.paygatehn.com
# Producción: https://api.paygatehn.com
PAYGATE_API_BASE=
# Token Bearer del merchant (sandbox o prod, según el entorno). NO commitear el valor real.
PAYGATE_BEARER_TOKEN=
# Secreto compartido para validar firma del webhook que envía Paygate al confirmar un pago.
PAYGATE_WEBHOOK_SECRET=
# Solo desarrollo local: permite POST /webhooks/paygate sin PAYGATE_WEBHOOK_SECRET (nunca en producción).
# PAYGATE_WEBHOOK_ALLOW_UNSIGNED=true
# Horas de vida del payment link antes de expirar (default 2).
PAYGATE_LINK_EXPIRATION_HOURS=2
# Moneda por defecto al crear payment links (ISO 4217).
PAYGATE_CURRENCY=HNL

# --- Feature flags (rollback rápido) ---
# Cuando false: deshabilita el inicio de pagos (POST /me/payments/initiate devuelve 503)
PAYMENTS_ENABLED=true
# Override de emergencia: trata todos los eventos como "sin pagos" (también devuelve 503 en initiate)
FORCE_FREE_EVENTS=false

# --- Ticket QR signing ---
# HMAC-SHA256 secret used to sign customer ticket QR codes. Without it,
# QRs ship unsigned (fine for local/dev). Production MUST set this — the
# scanner verifies the signature before accepting a ticket.
TICKET_QR_SECRET=

# --- Transactional mail (MAIL-001) ---
# Resend API key. Without it, MailService only logs (no real send) — fine for
# local/dev and tests. Production MUST set this after verifying the domain/DKIM.
RESEND_API_KEY=
# From address; the domain must be verified in Resend (SPF/DKIM).
MAIL_FROM=Allons <no-reply@allons.app>
# Optional link overrides for emails. Defaults are placeholders until the app
# is published and allons.app serves the Universal/App Links manifests.
# MAIL_APP_STORE_LINK=https://apps.apple.com/app/idXXXXXXXXX
# MAIL_PLAY_STORE_LINK=https://play.google.com/store/apps/details?id=com.fndrs.allons
# MAIL_DEEP_LINK_TICKETS=allons://tickets
# MAIL_WEB_FALLBACK_TICKETS=https://allons.app/tickets

# --- Provider fees (merchant net / payouts) ---
# Effective fee withheld from a merchant's sale = Allons commission + ISV on
# that commission + the per-comercio Paygate (bank) fee. These are the
# platform-wide rates (defaults shown); the Paygate % is per-comercio (set in
# allons-admin, stored in the owner's metadata) and falls back to the default.
# PLATFORM_ALLONS_FEE_PCT=12
# PLATFORM_ISV_PCT=15
# PLATFORM_PAYGATE_FEE_PCT_DEFAULT=5

# --- PostHog (analytics + error tracking) ---
# Ingest key — used by PostHogService to capture events/exceptions from the API.
POSTHOG_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
# Personal API key with Query read — used by admin overview (count $exception, 30 d).
# Create at PostHog → Settings → Personal API keys. Also set project ID from project settings.
POSTHOG_PERSONAL_API_KEY=
POSTHOG_PROJECT_ID=
