PORT=3000

# Supabase Postgres (Transaction pooler is recommended for serverless; direct is fine for dev)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres?schema=public

# Optional: Supabase Admin (server-side) access for auth/user-linked mutations
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
